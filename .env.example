# ── DevImpact frontend (Next.js) — environment template ────────────────────
# Copy to `.env.local` next to package.json. Secrets for DB / AI / webhooks live on the API server.
#
#   cp .env.example .env.local
#
# Base URL of devimpact-backend (Express). Browser calls `${this}/api/...`.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Multi-user / production: the API derives a per-user tenant id from the GitHub token using
# USER_ID_PEPPER on devimpact-backend. Each signed-in user gets isolated DB rows (commits,
# ai_analysis, etc.). Apply Supabase migrations under my-app/supabase/migrations (github_accounts).

# AI: set OPENROUTER_API_KEY in devimpact-backend/.env (recommended).
# Optional dev-only — exposes the key in the browser bundle:
# NEXT_PUBLIC_OPENROUTER_API_KEY=sk-or-v1-...

# ── GitHub OAuth (optional — server-only, never NEXT_PUBLIC_*) ──────────────
# Create an OAuth App: GitHub → Settings → Developer settings → OAuth Apps.
# Callback URL must match exactly, e.g. http://localhost:3000/api/auth/github/callback
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# GITHUB_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/github/callback

# Production example:
# NEXT_PUBLIC_BACKEND_URL=https://api.yourdomain.com
