# ── DevImpact frontend (Next.js) — environment template ────────────────────
# Copy to `.env.local` next to package.json. Secrets for DB / AI / webhooks live on the API server.
#
#   cp .env.example .env.local
#
# Base URL of devimpact-backend (Express). Browser calls `${this}/api/...`.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# AI: set OPENROUTER_API_KEY in devimpact-backend/.env (recommended).
# Optional dev-only — exposes the key in the browser bundle:
# NEXT_PUBLIC_OPENROUTER_API_KEY=sk-or-v1-...

# Production example:
# NEXT_PUBLIC_BACKEND_URL=https://api.yourdomain.com
