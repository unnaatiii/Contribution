# ── DevImpact AI — environment template ─────────────────────────────────────
# Copy this file to `.env.local` in this folder (same directory as package.json).
# Never commit `.env.local` — it holds secrets.
#
#   cp .env.example .env.local
#   # then edit .env.local and paste your real key
#
# OpenRouter (required for AI commit analysis)
OPENROUTER_API_KEY=

# Optional: URL shown to OpenRouter (some accounts expect a real referer)
# OPENROUTER_HTTP_REFERER=https://localhost:3000

# Optional: primary OpenRouter model id (see lib/ai-analyzer.ts defaults)
# OPENROUTER_ANALYSIS_MODEL=google/gemini-2.0-flash-001

# Optional: ms between AI *chunks* (batched OpenRouter calls); default 180
# OPENROUTER_COMMIT_DELAY_MS=200

# Optional: commits per OpenRouter request when analyzing (1–8); default 4
# OPENROUTER_AI_BATCH_SIZE=4

# Optional: max output tokens per batch request (defaults scale with batch size, cap ~12k)
# OPENROUTER_AI_BATCH_MAX_TOKENS=8000

# GitHub PAT needs `repo` scope. Listing repo collaborators may require admin on private repos.

#── Optional: persistent AI cache + analysis history (Supabase) ─────────────
# When all three are set, the server stores repos, commits, AI rows, and runs per hashed PAT.
# Use Project URL + service_role key from Supabase → Settings → API (not the anon key).
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# USER_ID_PEPPER=   # long random secret; used to hash PAT → user_id (required for multi-tenant writes)

#── GitHub org webhook (optional) ─────────────────────────────────────────────
# Secret you configure on the org webhook (Settings → Webhooks → Secret).
# GITHUB_ORG_SYNC_TOKEN: PAT or fine-grained token with repo read on org repos;
# used server-side when ≥5 new commits trigger batched AI (no browser PAT).
# GITHUB_WEBHOOK_SECRET=
# GITHUB_ORG_SYNC_TOKEN=
